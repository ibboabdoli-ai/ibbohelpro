# CleanAI production environment
# Copy these keys into Vercel Project Settings -> Environment Variables.

# Local API dev server
PORT=8787

# Required for real database persistence and server-only writes
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional public Supabase client configuration for future real auth.
# These are safe to expose in frontend builds. Do not put the service-role key here.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Required for admin approval endpoints
ADMIN_API_TOKEN=

# Optional AI provider. Without this key, deterministic fallback still works.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AI_RATE_LIMIT_MAX=30

# Optional CORS lock-down. Example: https://your-domain.vercel.app
APP_ORIGIN=
