# Local dev API server
PORT=3000

# Restrict serverless API CORS in production, for example:
# APP_ORIGIN=https://your-domain.com
APP_ORIGIN=*

# Optional: Supabase persistence for bookings/provider applications
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Optional: OpenAI assistant endpoint
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Optional: admin-only provider approval endpoint
# ADMIN_API_TOKEN=change-me
